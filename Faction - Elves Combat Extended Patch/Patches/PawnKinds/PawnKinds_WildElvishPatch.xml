<!-- Civilians -->
<!-- ================================================= -->

<!-- Trader -->
<!-- ================================================= -->
<Operation Class="PatchOperationConditional">
    <xpath>Defs/PawnKindDef[defName="WildElvish_Trader"]/apparelRequired</xpath>

    <nomatch Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[defName="WildElvish_Trader"]</xpath>
        <value>
            <apparelRequired>
                <li>CE_Apparel_Backpack</li>
            </apparelRequired>
        </value>
    </nomatch>

    <match Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[defName="WildElvish_Trader"]/apparelRequired</xpath>
        <value>
            <li>CE_Apparel_Backpack</li>
        </value>
    </match>
</Operation>


