<?xml version="1.0" encoding="utf-8"?>
<Patch>

    <!-- ================================================= -->
    <!-- Circlet -->
    <!-- ================================================= -->

    <!-- CE Stats -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Apparel_Circlet"]/statBases/Mass</xpath>
        <value>
            <Bulk>2</Bulk>
            <WornBulk>0.15</WornBulk>
            <Mass>0.4</Mass>
        </value>
    </Operation>


    <!-- ================================================= -->
    <!-- Duelist Plate Armor -->
    <!-- ================================================= -->

    <!-- CE Weight -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Apparel_DuelistPlateArmor"]/statBases/Mass</xpath>
        <value>
            <Bulk>50</Bulk>
            <WornBulk>6.5</WornBulk>
            <Mass>12</Mass>
        </value>
    </Operation>

    <!-- CE Armor Multipliers -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Apparel_DuelistPlateArmor"]/statBases/StuffEffectMultiplierArmor</xpath>
        <value>
            <StuffEffectMultiplierArmor>1.5</StuffEffectMultiplierArmor>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Apparel_DuelistPlateArmor"]/statBases/StuffEffectMultiplierInsulation_Cold</xpath>
        <value>
            <StuffEffectMultiplierInsulation_Cold>0.10</StuffEffectMultiplierInsulation_Cold>
        </value>
    </Operation>

    <!-- CE Equipped Stats -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="Apparel_DuelistPlateArmor"]/equippedStatOffsets</xpath>
        <value>
            <equippedStatOffsets>
                <MeleeDodgeChance>0.15</MeleeDodgeChance>
                <MoveSpeed>-0.6</MoveSpeed>
            </equippedStatOffsets>
        </value>
    </Operation>

    <!-- CE Partial Armor -->
    <Operation Class="PatchOperationAddModExtension">
        <xpath>Defs/ThingDef[defName="Apparel_DuelistPlateArmor"]</xpath>
        <value>

            <li Class="CombatExtended.PartialArmorExt">

                <stats>

                    <li>
                        <ArmorRating_Sharp>0.65</ArmorRating_Sharp>
                        <parts>
                            <li>Arm</li>
                        </parts>
                    </li>

                    <li>
                        <ArmorRating_Blunt>0.65</ArmorRating_Blunt>
                        <parts>
                            <li>Arm</li>
                        </parts>
                    </li>

                </stats>

            </li>

        </value>
    </Operation>

</Patch>