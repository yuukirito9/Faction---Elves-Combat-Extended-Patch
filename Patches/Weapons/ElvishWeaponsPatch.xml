            </tools>
        </value>
    </Operation>

    <!-- CE Stats -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="MeleeWeapon_Rapier"]/statBases</xpath>

        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="MeleeWeapon_Rapier"]</xpath>
        <value>
            <statBases/>
        </value>
        </nomatch>
    </Operation>

    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="MeleeWeapon_Rapier"]/statBases</xpath>
        <value>
            <Bulk>3.5</Bulk>
            <MeleeCounterParryBonus>0.75</MeleeCounterParryBonus>
        </value>
    </Operation>

<!-- CE Equipped Stats -->

    <Operation Class="PatchOperationConditional">
    <xpath>Defs/ThingDef[defName="MeleeWeapon_Rapier"]/equippedStatOffsets</xpath>

    <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="MeleeWeapon_Rapier"]</xpath>
        <value>
            <equippedStatOffsets/>
        </value>
    </nomatch>
    </Operation>

    <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="MeleeWeapon_Rapier"]/equippedStatOffsets</xpath>
    <value>
        <MeleeCritChance>0.25</MeleeCritChance>
        <MeleeParryChance>0.60</MeleeParryChance>
        <MeleeDodgeChance>0.30</MeleeDodgeChance>
