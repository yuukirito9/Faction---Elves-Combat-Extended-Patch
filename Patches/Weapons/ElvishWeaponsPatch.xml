    </Operation>
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="MeleeWeapon_Rapier"]/weaponTags</xpath>
        <value>
            <li>CE_OneHandedWeapon</li>
        </value>
    </Operation>


