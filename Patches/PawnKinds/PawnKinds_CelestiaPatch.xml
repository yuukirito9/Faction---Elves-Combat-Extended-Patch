<!-- Civilians -->
<!-- ================================================= -->

<!-- Council -->
<!-- ================================================= -->
<Operation Class="PatchOperationConditional">
    <xpath>Defs/PawnKindDef[defName="CelestiaElvish_Council"]/apparelRequired</xpath>

    <nomatch Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[defName="CelestiaElvish_Council"]</xpath>
        <value>
            <apparelRequired>
                <li>CE_Apparel_Backpack</li>
            </apparelRequired>
        </value>
    </nomatch>

    <match Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[defName="CelestiaElvish_Council"]/apparelRequired</xpath>
        <value>
            <li>CE_Apparel_Backpack</li>
        </value>
    </match>
</Operation>


