<!-- ================================================= -->


<!-- Emperor -->
<!-- ================================================= -->
<Operation Class="PatchOperationConditional">
    <xpath>Defs/PawnKindDef[defName="HighElvish_Emperor"]/apparelRequired</xpath>

    <nomatch Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[defName="HighElvish_Emperor"]</xpath>
        <value>
            <apparelRequired>
                <li>CE_Apparel_Backpack</li>
            </apparelRequired>
        </value>
    </nomatch>

    <match Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[defName="HighElvish_Emperor"]/apparelRequired</xpath>
        <value>
            <li>CE_Apparel_Backpack</li>
        </value>
    </match>
</Operation>


