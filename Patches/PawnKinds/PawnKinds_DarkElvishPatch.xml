<?xml version="1.0" encoding="utf-8" ?>
<Patch>

<!-- ================================================= -->
<!-- Civilians -->
<!-- ================================================= -->

<!-- DarkElvish_Lord -->
<!-- ================================================= -->
<Operation Class="PatchOperationConditional">
    <xpath>Defs/PawnKindDef[defName="DarkElvish_Lord"]/apparelRequired</xpath>

    <nomatch Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[defName="DarkElvish_Lord"]</xpath>
        <value>
            <apparelRequired>
                <li>CE_Apparel_Backpack</li>
            </apparelRequired>
        </value>
    </nomatch>

    <match Class="PatchOperationAdd">
        <xpath>Defs/PawnKindDef[defName="DarkElvish_Lord"]/apparelRequired</xpath>
        <value>
            <li>CE_Apparel_Backpack</li>
        </value>
    </match>
</Operation>


