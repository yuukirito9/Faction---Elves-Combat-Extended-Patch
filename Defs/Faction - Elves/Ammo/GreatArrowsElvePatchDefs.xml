<Defs>

	<ThingCategoryDef>
		<defName>AmmoGreatLongArrow</defName>
		<label>great long arrows</label> 
		<parent>AmmoNeolithic</parent>
		<iconPath>UI/Icons/ThingCategories/CaliberArrow</iconPath>
	</ThingCategoryDef>

	<!-- ==================== AmmoSet ========================== --> 

	<CombatExtended.AmmoSetDef>
		<defName>AmmoSet_GreatLongArrow</defName>
		<label>great long arrows</label>
		<ammoTypes>
			<Ammo_GreatLongArrow_Stone>Projectile_GreatLongArrow_Stone</Ammo_GreatLongArrow_Stone>
			<Ammo_GreatLongArrow_Steel>Projectile_GreatLongArrow_Steel</Ammo_GreatLongArrow_Steel>
			<Ammo_GreatLongArrow_Plasteel>Projectile_GreatLongArrow_Plasteel</Ammo_GreatLongArrow_Plasteel>
			<Ammo_GreatLongArrow_Venom>Projectile_GreatLongArrow_Venom</Ammo_GreatLongArrow_Venom>
			<Ammo_GreatLongArrow_Flame>Projectile_GreatLongArrow_Flame</Ammo_GreatLongArrow_Flame>
		</ammoTypes>
	</CombatExtended.AmmoSetDef>

	<!-- ==================== Ammo ========================== -->

	<ThingDef Class="CombatExtended.AmmoDef" Name="AmmoSet_GreatLongArrowBase" ParentName="NeolithicAmmoBase" Abstract="True">
		<description>Heavy long arrow designed to be fired from a long great bow.</description>
		<statBases>
			<Mass>0.075</Mass>
			<Bulk>0.5</Bulk>
			<Flammability>1</Flammability>
		</statBases>
		<thingCategories>
			<li>AmmoGreatLongArrow</li>
		</thingCategories>
		<stackLimit>500</stackLimit>
		<tradeTags>
			<li>CE_PreIndustrialAmmo</li>
			<li>CE_AutoEnableTrade</li>
			<li>CE_AutoEnableCrafting_FueledSmithy</li>
			<li>CE_AutoEnableCrafting_ElectricSmithy</li>
		</tradeTags>
	</ThingDef>

