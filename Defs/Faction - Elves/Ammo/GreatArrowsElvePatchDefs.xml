		<label>make stone long great arrows x10</label>
		<description>Craft 10 stone long great arrows.</description>
		<jobString>Making stone long great arrows.</jobString>
		<workAmount>400</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>WoodLog</li>
